#controller
PORT=3000

#database
SMS_DB_URL = mongodb://localhost:27017/shop-management-system
MONGO_LOGGER_LEVEL = info

#cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

#user
USER_JWT_SECRET=
USER_ACCESS_JWT_EXPIRES_IN=5m
USER_REFRESH_JWT_EXPIRES_IN=24h
USER_PASSWORD_SALT_ROUNDS=10

#gst (Whitebooks GST API)
GST_BASE_URL=https://api.whitebooks.in/v1
GST_CLIENT_ID=your-gst-client-id
GST_CLIENT_SECRET=your-gst-client-secret
GST_IP_ADDRESS=127.0.0.1
GST_TIMEOUT=30000
GST_RETRY_ATTEMPTS=3
GST_RETRY_DELAY=1000

#ai (OpenAI - used for AI-enabled GST filing)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT=30000